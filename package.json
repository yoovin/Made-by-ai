{
  "name": "made-by-ai",
  "private": true,
  "version": "0.1.0",
  "description": "허브형 웹서비스 + 로컬 OpenCode 자율 개발 스타터",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
